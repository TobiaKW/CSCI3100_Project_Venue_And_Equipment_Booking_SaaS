<%= link_to "<span class='material-symbols-outlined'>arrow_back</span>Back to Resources".html_safe, root_path, class: "back-btn" %>

<div class="admin-dashboard">
  <h1>Admin Dashboard</h1>

  <div class="department-name">
    <div class="item-label">Department</div>
    <span class="material-symbols-outlined">location_on</span>
    <%= Department.find(current_user.department_id).name %>
  </div>

  <!-- Pending Bookings Table -->
  <section>
    <h2>Pending Bookings</h2>
    <% if @pending_bookings.any? %>
      <table class="bookings-table">
        <thead>
          <tr>
            <th>User</th>
            <th>Resource</th>
            <th>Start Time</th>
            <th>End Time</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody data-bookings-list>
          <% @pending_bookings.each do |booking| %>
            <%= render "admin/bookings/booking_row", booking: booking %>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <div class="no-data">No pending bookings</div>
    <% end %>
  </section>

  <!-- This Week's Approved Bookings Table -->
  <section>
    <h2>Approved Bookings This Week</h2>
    <% if @week_bookings.any? %>
      <table class="bookings-table">
        <thead>
          <tr>
            <th>User</th>
            <th>Resource</th>
            <th>Start Time</th>
            <th>End Time</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody>
          <% @week_bookings.each do |booking| %>
            <tr>
              <td><%= booking.user.name %></td>
              <td><%= booking.resource.name %></td>
              <td><%= booking.start_time.strftime("%Y-%m-%d %H:%M") %></td>
              <td><%= booking.end_time.strftime("%Y-%m-%d %H:%M") %></td>
              <td><span class="badge badge-confirmed"><%= booking.status %></span></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <div class="no-data">No approved bookings this week</div>
    <% end %>
  </section>

  <!-- Charts Section -->
  <section class="charts-grid">
    <div>
      <h2>Bookings by Status</h2>
      <%= pie_chart @bookings_by_status, library: { pieHole: 0.4 } %>
    </div>

    <div>
      <h2>Booking Trends</h2>
      <%= line_chart @booking_trends %>
    </div>

    <div>
      <h2>Top Resources</h2>
      <%= bar_chart @resource_utilization %>
    </div>
  </section>
</div>