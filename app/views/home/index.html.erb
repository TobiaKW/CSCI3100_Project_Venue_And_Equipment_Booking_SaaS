<% if user_signed_in? %>
  <!-- Search Section -->
  <%= render "search_bar" %>

  <!-- Resources Grid -->
  <div class="resources-section">
    <h1 class="resources-section-title">Available Resources <span class="count"><%= @resources.count %></span></h1>
    
    <% if @resources.any? %>
      <div class="resources-grid">
        <% @resources.each do |resource| %>
          <%= render "resource_card", resource: resource %>
        <% end %>
      </div>
    <% else %>
      <div class="empty-state">
        <div class="empty-state-icon"><span class="material-symbols-outlined">markunread_mailbox</span></div>
        <div class="empty-state-text">No resources found.<br>Try adjusting your search filters.</div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="card" style="text-align: center; padding: 3rem;">
    <h1>Welcome to the Booking System</h1>
    <p>Please log in to view and book resources.</p>
  </div>
<% end %>