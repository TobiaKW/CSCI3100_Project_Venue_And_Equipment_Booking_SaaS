<div class="dashboard-container">
  <!-- Header Section -->
  <div class="dashboard-header">
    <h1 class="dashboard-title">🏢 Venue & Equipment Booking</h1>
    
    <% if user_signed_in? %>
      <div class="dashboard-user-info">
        <span class="user-badge">👤 <%= current_user.name %> (<%= current_user.role %>)</span>
        <% if current_user.role == "admin" %>
          <%= link_to "Admin Dashboard", admin_bookings_path, class: "btn btn-secondary" %>
        <% else %>
          <%= link_to "My Bookings", bookings_path, class: "btn btn-secondary" %>
        <% end %>
        <%= button_to "Log out", destroy_user_session_path, method: :delete, class: "btn" %>
      </div>
    <% else %>
      <div class="dashboard-user-info">
        <%= button_to "Log in", new_user_session_path, method: :get, class: "btn" %>
        <%= button_to "Sign up", new_user_registration_path, method: :get, class: "btn btn-secondary" %>
      </div>
    <% end %>
  </div>

  <% if user_signed_in? %>
    <!-- Search Section -->
    <div class="search-section">
      <%= form_with url: root_path, method: :get, local: true, class: "search-form" do |f| %>
        <div class="search-input-group">
          <%= f.label :search, "🔍 Search by name:", style: "font-weight: 600;" %>
          <%= f.text_field :search, value: params[:search], placeholder: "Enter resource name...", class: "search-input" %>
          
          <div class="filter-checkboxes">
            <label class="filter-checkbox-label">
              <%= f.check_box :rtypes, { multiple: true, checked: params[:rtypes]&.include?("room") }, "room", nil %>
              🏠 Room
            </label>
            <label class="filter-checkbox-label">
              <%= f.check_box :rtypes, { multiple: true, checked: params[:rtypes]&.include?("equipment") }, "equipment", nil %>
              🔧 Equipment
            </label>
          </div>
        </div>

        <div>
          <%= f.submit "Search", class: "search-btn" %>
        </div>
      <% end %>
    </div>

    <!-- Resources Grid -->
    <h2 class="resources-section-title">Available Resources (<%= @resources.count %>)</h2>
    
    <% if @resources.any? %>
      <div class="resources-grid">
        <% @resources.each do |resource| %>
          <div class="resource-card">
            <div class="resource-card-header type-<%= resource.rtype %>">
              <span class="resource-type-badge"><%= resource.rtype %></span>
              <h3 class="resource-name"><%= resource.name %></h3>
              <div class="resource-department">
                📍 <%= resource.department.name %>
              </div>
            </div>
            
            <div class="resource-card-body">
              <div class="resource-details">
                <div class="resource-detail-item">
                  <span class="resource-detail-label">Type</span>
                  <span class="resource-detail-value"><%= resource.rtype.capitalize %></span>
                </div>
                <% if resource.rtype == 'room' && resource.capacity && resource.capacity > 0 %>
                  <div class="resource-detail-item">
                    <span class="resource-detail-label">👥 Capacity</span>
                    <span class="resource-detail-value"><%= resource.capacity %> seats</span>
                  </div>
                  <div class="resource-detail-item">
                    <span class="resource-detail-label">💺 Seat Type</span>
                    <span class="resource-detail-value"><%= resource.seat_type %></span>
                  </div>
                <% end %>
                <div class="resource-detail-item">
                  <span class="resource-detail-label">Department</span>
                  <span class="resource-detail-value"><%= resource.department.name %></span>
                </div>
              </div>
            </div>
            
            <div class="resource-card-footer">
              <%= link_to "📅 Book Now", new_booking_path(resource_id: resource.id), class: "book-btn" %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="empty-state">
        <div class="empty-state-icon">📭</div>
        <p class="empty-state-text">No resources found. Try adjusting your search filters.</p>
      </div>
    <% end %>
  <% else %>
    <div class="card" style="text-align: center; padding: 3rem;">
      <h2>Welcome to the Booking System</h2>
      <p>Please log in to view and book resources.</p>
    </div>
  <% end %>
</div>