<div class="dashboard-container">
  <% if user_signed_in? %>
    <!-- Search Section -->
    <div class="search-section">
      <%= form_with url: root_path, method: :get, local: true, class: "search-form" do |f| %>
        <div class="search-input-group">
          <%= f.label :search, "<span class='material-symbols-outlined'>search</span> Search by name:".html_safe, style: "font-weight: 600;" %>
          <%= f.text_field :search, value: params[:search], placeholder: "Enter resource name...", class: "search-input" %>
          
          <div>
            <%= f.label :department_id, "Department:", style: "font-weight: 600;" %>
            <%= f.collection_select :department_id, Department.all, :id, :name, { prompt: "All Departments" }, class: "filter-select" %>
          </div>

          <div class="filter-checkboxes">
            <label class="filter-checkbox-label">
              <%= f.check_box :rtypes, { multiple: true, checked: params[:rtypes]&.include?("room") }, "room", nil %>
              <span class="material-symbols-outlined">home</span>
              Room
            </label>
            <label class="filter-checkbox-label">
              <%= f.check_box :rtypes, { multiple: true, checked: params[:rtypes]&.include?("equipment") }, "equipment", nil %>
              <span class="material-symbols-outlined">build</span>
              Equipment
            </label>
          </div>
        </div>

        <div>
          <%= f.submit "Search", class: "search-btn" %>
        </div>
      <% end %>
    </div>

    <!-- Resources Grid -->
    <div class="resources-section">
      <div class="resources-section-title">Available Resources <span class="count"><%= @resources.count %></span></div>
      
      <% if @resources.any? %>
        <div class="resources-grid">
          <% @resources.each do |resource| %>
            <div class="resource-card">
              <div class="resource-card-header type-<%= resource.rtype %>">
                <div class="resource-type-icon">
                  <% if resource.rtype == 'room' %>
                    <span class="material-symbols-outlined">home</span>
                  <% else %>
                    <span class="material-symbols-outlined">build</span>
                  <% end %>
                </div>
                <div class="resource-type-label"><%= resource.rtype %></div>
                <div class="resource-name"><%= resource.name %></div>
                <div class="resource-department">
                  <div class="hover-label">Department</div>
                  <span class="material-symbols-outlined">location_on</span>
                  <%= resource.department.name %>
                </div>
              </div>
              
              <% if resource.rtype == 'room' && resource.capacity && resource.capacity > 0 %>
                <div class="resource-card-body">
                  <div class="resource-details">
                    <div class="resource-detail-item">
                      <div class="hover-label">Capacity</div>
                      <span class="material-symbols-outlined">groups</span>
                      <span class="resource-detail-value"><%= resource.capacity %> seats</span>
                    </div>
                    <div class="resource-detail-item">
                      <div class="hover-label">Seat Type</div>
                      <span class="material-symbols-outlined">tatami_seat</span>
                      <span class="resource-detail-value"><%= resource.seat_type %></span>
                    </div>
                  </div>
                </div>
              <% end %>
              
              <div class="resource-card-footer">
                <%= link_to "<button class='book-btn'><span class='material-symbols-outlined'>calendar_add_on</span> Book Now</button>".html_safe, new_booking_path(resource_id: resource.id) %>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="empty-state">
          <div class="empty-state-icon"><span class="material-symbols-outlined">markunread_mailbox</span></div>
          <p class="empty-state-text">No resources found. Try adjusting your search filters.</p>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="card" style="text-align: center; padding: 3rem;">
      <h2>Welcome to the Booking System</h2>
      <p>Please log in to view and book resources.</p>
    </div>
  <% end %>
</div>