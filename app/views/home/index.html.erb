<h1>Venue & Equipment Booking</h1>

<% if user_signed_in? %>
  <p>Welcome, <%= current_user.name %> (<%= current_user.role %>)</p>
  <% if current_user.role == "admin" %>
    <%= button_to "Admin Dashboard", admin_bookings_path, method: :get %>
  <% else %>
    <%= button_to "My Bookings", bookings_path, method: :get %>
  <% end %>
  <%= button_to "Log out", destroy_user_session_path, method: :delete %>
<% else %>
  <p>
    <%= button_to "Log in", new_user_session_path, method: :get %>
    <%= button_to "Sign up", new_user_registration_path, method: :get %>
  </p>
<% end %>

<hr>

<% if user_signed_in? %>
  <h3>Search Resources</h3>
  <%= form_with url: root_path, method: :get, local: true do |f| %>
    <div>
      <%= f.label :search, "Search by name:" %>
      <%= f.text_field :search, value: params[:search] %>
    </div>

    <div>
      <p>Filter by type:</p>
      <%= f.check_box :rtypes, { multiple: true, checked: params[:rtypes]&.include?("room") }, "room", nil %> Room
      <%= f.check_box :rtypes, { multiple: true, checked: params[:rtypes]&.include?("equipment") }, "equipment", nil %> Equipment
    </div>

    <div>
      <%= f.submit "Search" %>
    </div>
  <% end %>

  <hr>

  <h3>Available Resources</h3>
  <table border="1">
    <thead>
      <tr>
        <th>Name</th>
        <th>Type</th>
        <th>Department</th>
        <th>Action</th>
      </tr>
    </thead>
    <tbody>
      <% @resources.each do |resource| %>
        <tr>
          <td><%= resource.name %></td>
          <td><%= resource.rtype %></td>
          <td><%= resource.department.name %></td>
          <td>
            <%= link_to "Book", new_booking_path(resource_id: resource.id) %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p>Please log in to view and book resources.</p>
<% end %>