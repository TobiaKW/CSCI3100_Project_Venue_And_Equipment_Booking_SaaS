<%= link_to "<span class='material-symbols-outlined'>arrow_back</span>Back to Resources".html_safe, root_path, class: "back-btn" %>

<div class="resources-section">
  <h1 class="resources-section-title">My Bookings <span class="count"><%= @bookings.count %></span></h1>
  <% if @bookings.any? %>
    <div class="resources-grid">
      <% @bookings.each do |booking| %>
        <div class="resource-card" data-booking-id="<%= booking.id %>">
          <div class="resource-card-header type-<%= booking.resource.rtype %>">
            <div class="resource-type-icon">
              <% if booking.resource.rtype == 'room' %>
                <span class="material-symbols-outlined">home</span>
              <% else %>
                <span class="material-symbols-outlined">build</span>
              <% end %>
            </div>
            <div class="resource-type-label"><%= booking.resource.rtype %></div>
            <div class="resource-name"><%= booking.resource.name %></div>
            <div class="resource-department">
              <div class="hover-label">Department</div>
              <span class="material-symbols-outlined">location_on</span>
              <%= booking.resource.department.name %>
            </div>
          </div>

          <div class="resource-card-body">
            <div class="resource-details">
              <div class="resource-detail-item">
                <div class="hover-label">Start Time</div>
                <span class="resource-detail-value"><%= booking.start_time.strftime("%Y-%m-%d %H:%M") %></span>
              </div>
              <span class="material-symbols-outlined">trending_flat</span>
              <div class="resource-detail-item">
                <div class="hover-label">End Time</div>
                <span class="resource-detail-value"><%= booking.end_time.strftime("%Y-%m-%d %H:%M") %></span>
              </div>
            </div>
          </div>

          <div class="resource-card-footer">
            <div class="booking-status">
              <div class="hover-label">Status</div>
              <div><%= booking.status %></div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="empty-state">
      <div class="empty-state-icon"><span class="material-symbols-outlined">markunread_mailbox</span></div>
      <div class="empty-state-text">You don't have any bookings yet.</div>
    </div>
  <% end %>
</div>
