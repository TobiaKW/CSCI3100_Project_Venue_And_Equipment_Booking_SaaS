<%= link_to "<span class='material-symbols-outlined'>arrow_back</span>Back to Resources".html_safe, root_path, class: "back-btn" %>

<h1>Make a Booking</h1>

<div class="booking-info">
  <div class="resource-type-label">
    <% if @resource.rtype == 'room' %>
      <span class="material-symbols-outlined">home</span>
    <% else %>
      <span class="material-symbols-outlined">build</span>
    <% end %>
    <%= @resource.rtype %>
  </div>
  <div class="resource-name"><%= @resource.name %></div>
  <div class="booking-item">
    <div class="item-label">Department</div>
    <span class="material-symbols-outlined">location_on</span>
    <div class="item-value"><%= @resource.department.name %></div>
  </div>
  <% if @resource.rtype == 'room' && @resource.capacity && @resource.capacity > 0 %>
    <div class="booking-details">
      <div class="booking-item">
        <div class="item-label">Capacity</div>
        <span class="material-symbols-outlined">groups</span>
        <div class="item-value"><%= @resource.capacity %> seats</div>
      </div>
      <div class="booking-item">
        <div class="item-label">Seat Type</div>
        <span class="material-symbols-outlined">tatami_seat</span>
        <div class="item-value"><%= @resource.seat_type %></div>
      </div>
    </div>
  <% end %>

  <div class="location-map-section">
    <div class="item-label">Location Map</div>
    <% if @resource.has_location? %>
      <% map_query = resource_map_query(@resource) %>
      <iframe
        class="location-map"
        title="Location map for <%= @resource.name %>"
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        src="https://maps.google.com/maps?q=<%= ERB::Util.url_encode(map_query) %>&z=19&output=embed">
      </iframe>
    <% elsif @resource.rtype == 'equipment' %>
      <div class="location-map-fallback">No location map for this resource.</div>
    <% else %>
      <div class="location-map-fallback">Location map is not available for this resource yet.</div>
    <% end %>
  </div>
</div>

<%= form_with model: @booking, url: bookings_path(resource_id: @resource.id), local: true, class: "booking-form" do |f| %>
  <% if @booking.errors.any? %>
    <div class="error-explanation">
      <div class="error-title">Error</div>
      <ul>
        <% @booking.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-row">
    <div class="form-group">
      <%= f.label :start_time, "Start Time" %>
      <%= f.datetime_field :start_time, value: @booking.start_time, data: { field: 'start-date' } %>
    </div>

    <span class="material-symbols-outlined">trending_flat</span>

    <div class="form-group">
      <%= f.label :end_time, "End Time" %>
      <%= f.datetime_field :end_time, value: @booking.end_time, data: { field: 'end-date' } %>
    </div>
  </div>

  <div class="form-actions">
    <%= f.submit "Confirm Booking" %>
  </div>
<% end %>
