<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Proj" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="manifest" href="/manifest.json">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.svg">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@100..900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-adapter-date-fns@3"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartkick@5"></script>
    <%= stylesheet_link_tag "application" %>
    <%= javascript_importmap_tags %>

    <script>
      function setTheme(themeName) {
        localStorage.setItem("theme", themeName);
        document.documentElement.classList.remove("light");
        document.documentElement.classList.remove("dark");
        document.documentElement.classList.add(themeName);
      }

      function changeTheme() {
        if (localStorage.getItem("theme") === "dark"){
          setTheme("light");
        } else{
          setTheme("dark");
        }
      }

      (() => {
        if (localStorage.getItem("theme") === "dark") {
          setTheme("dark");
          return;
        }
        if (localStorage.getItem("theme") === "light") {
          setTheme("light");
          return;
        }
        var preference = window.matchMedia("(prefers-color-scheme: dark)");
        if (preference.matches) {
          setTheme("dark");
        } else {
          setTheme("light");
        }
      })();
    </script>
  </head>

  <body>
    <header>
      <%= link_to root_path do %>
        <div class="title"><span class="material-symbols-outlined">corporate_fare</span> Venue & Equipment Booking</div>
      <% end %>
      
      <div class="info">
        <% if user_signed_in? %>
          <div class="user-info">
            <span class="user-badge"><span class="material-symbols-outlined">person</span> <%= current_user.name %> (<%= current_user.role %>)</span>
            <% if current_user.role == "admin" %>
              <%= link_to "Admin Dashboard", admin_bookings_path, class: "btn btn-secondary" %>
            <% else %>
              <%= link_to "My Bookings", bookings_path, class: "btn btn-secondary" %>
            <% end %>
            <%= button_to "Log out", destroy_user_session_path, method: :delete, class: "btn" %>
          </div>
        <% else %>
          <% unless current_page?(new_user_session_path) || current_page?(new_user_registration_path) %>
            <div class="dashboard-user-info">
              <%= button_to "Log in", new_user_session_path, method: :get, class: "btn" %>
              <%= button_to "Sign up", new_user_registration_path, method: :get, class: "btn btn-secondary" %>
            </div>
          <% end %>
        <% end %>

        <button class="toggle-theme" title="Toggle Theme" onclick="changeTheme()">
          <div class="logo theme-light"></div>
          <div class="logo theme-dark"></div>
        </button>
      </div>
    </header>

    <div class="alerts-container">
      <% if notice.present? %><div class="alert alert-success"><%= notice %></div><% end %>
      <% if alert.present? %><div class="alert alert-error"><%= alert %></div><% end %>
    </div>

    <main>
      <%= yield %>
    </main>
  </body>
</html>
